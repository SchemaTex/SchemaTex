{
  "name": "lineage",
  "version": "0.1.0",
  "description": "Text-to-diagram rendering engine for genograms, ecomaps, and pedigree charts. Like Mermaid, but for relationship diagrams.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./genogram": {
      "types": "./dist/diagrams/genogram/index.d.ts",
      "import": "./dist/diagrams/genogram/index.js",
      "require": "./dist/diagrams/genogram/index.cjs"
    },
    "./ecomap": {
      "types": "./dist/diagrams/ecomap/index.d.ts",
      "import": "./dist/diagrams/ecomap/index.js",
      "require": "./dist/diagrams/ecomap/index.cjs"
    },
    "./pedigree": {
      "types": "./dist/diagrams/pedigree/index.d.ts",
      "import": "./dist/diagrams/pedigree/index.js",
      "require": "./dist/diagrams/pedigree/index.cjs"
    },
    "./phylo": {
      "types": "./dist/diagrams/phylo/index.d.ts",
      "import": "./dist/diagrams/phylo/index.js",
      "require": "./dist/diagrams/phylo/index.cjs"
    },
    "./sociogram": {
      "types": "./dist/diagrams/sociogram/index.d.ts",
      "import": "./dist/diagrams/sociogram/index.js",
      "require": "./dist/diagrams/sociogram/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "genogram",
    "ecomap",
    "pedigree",
    "phylogenetic",
    "sociogram",
    "family-tree",
    "diagram",
    "svg",
    "social-work",
    "therapy",
    "medical",
    "visualization",
    "text-to-diagram",
    "mermaid-alternative"
  ],
  "author": "Victor <victor@mymap.ai>",
  "license": "AGPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "https://github.com/mymap-ai/lineage"
  },
  "homepage": "https://github.com/mymap-ai/lineage#readme",
  "bugs": {
    "url": "https://github.com/mymap-ai/lineage/issues"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.58.2",
    "vitest": "^2.0.0"
  }
}
