      "require": "./dist/react.cjs"
    },
    "./export": {
      "types": "./dist/export.d.ts",
      "import": "./dist/export.js",
      "require": "./dist/export.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
